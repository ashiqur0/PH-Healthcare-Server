<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Google Login</title>
</head>

<body>
    <div>
        <p>Redirecting To Google...</p>
    </div>
</body>
<script>
    (
        async () => {
            try {
                const response = await fetch("<%= betterAuthUrl %>/api/auth/sign-in/social", {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/json"
                    },
                    credentials: "include",
                    body: JSON.stringify({
                        provider: "google",
                        callBackURL: "<%= callbackURL %>"
                    }),
                });

                const data = await response.json();

                if (data.url) {
                    window.location.href = data.url;
                } else {
                    document.body.innerHTML = `
                    <div>
                        <p>Failed to initiate Google login. Try again later.</p>
                    </div>`
                }
            } catch (error) {
                document.body.innerHTML = `
                <div>
                    <p>Error occurred while redirecting to Google. Please try again later. ${error.message}</p>
                </div>
                `;
            }
        }
    )()
</script>
</html>